{
  "mcpServers": {
    "skywatch-mcp": {
      "command": "bash",
      "args": ["-c", "cd servers/skywatch-mcp && bun install --silent 2>/dev/null && bun run src/index.ts"],
      "cwd": ".",
      "env": {
        "CLICKHOUSE_MODE": "ssh",
        "CLICKHOUSE_HOST": "http://localhost",
        "CLICKHOUSE_PORT": "8123",
        "CLICKHOUSE_USER": "default",
        "CLICKHOUSE_PASSWORD": "",
        "CLICKHOUSE_DATABASE": "default",
        "SSH_HOST": "",
        "SSH_USER": "",
        "SSH_DOCKER_CONTAINER": "",
        "OZONE_SERVICE_URL": "",
        "OZONE_ADMIN_PASSWORD": "",
        "OZONE_DID": ""
      }
    }
  }
}
