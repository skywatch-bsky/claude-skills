{
  "mcpServers": {
    "skywatch-mcp": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "${CLAUDE_PLUGIN_ROOT}/servers/skywatch-mcp",
        "skywatch-mcp"
      ],
      "env": {}
    },
    "pdsx": {
      "command": "uvx",
      "args": ["--from", "pdsx[mcp]", "pdsx-mcp"]
    },
    "atproto": {
      "command": "uvx",
      "args": ["atproto-mcp"]
    },
    "pub-search": {
      "type": "http",
      "url": "https://pub-search-by-zzstoatzz.fastmcp.app/mcp"
    }
  }
}
